<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FF161B22"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingHorizontal="32dp"
    android:paddingTop="32dp"
    android:paddingBottom="20dp">

    <!-- App Icon -->
    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/deploy_icon_bg"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvDeployIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="🚀"
            android:textSize="32sp" />
    </FrameLayout>

    <!-- App Name -->
    <TextView
        android:id="@+id/tvDeployAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginBottom="6dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ready to deploy"
        android:textColor="#FF8B949E"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="24dp" />

    <!-- Info Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/deploy_card_bg"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Type"
                android:textColor="#FF8B949E"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mini App"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Runtime"
                android:textColor="#FF8B949E"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Native"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Storage"
                android:textColor="#FF8B949E"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvDeploySize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Local"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </LinearLayout>
    </LinearLayout>

    <!-- Buttons -->
    <TextView
        android:id="@+id/btnDeployYes"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/deploy_btn_primary"
        android:gravity="center"
        android:text="Add to Homescreen"
        android:textColor="#FF000000"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/btnDeployNo"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center"
        android:text="Just Open"
        android:textColor="#FF8B949E"
        android:textSize="14sp"
        android:fontFamily="monospace" />

</LinearLayout>
