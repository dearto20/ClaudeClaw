{
  "statusLine": {
    "type": "command",
    "command": "node harness/scripts/harness.mjs status --line"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node harness/scripts/runtime-hooks/prompt-context.mjs"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node harness/scripts/runtime-hooks/session-start-context.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node harness/scripts/runtime-hooks/stop-tier-line-check.mjs"
          }
        ]
      }
    ]
  }
}
